# LOCAL DEV: leave VITE_API_URL empty (or omit this file entirely).
# The Vite dev/preview proxy in vite.config.ts forwards /api/* to the local
# backend transparently — no CORS issues, no extra config needed.
#
# PRODUCTION (Vercel): set VITE_API_URL as a build-time env var in your
# Vercel dashboard or via the GitHub Actions secret VITE_API_URL.
#
# VITE_API_URL=https://event-scheduler-api-ew.a.run.app
